      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="8" />
    <PackageReference Include="Microsoft.Identity.Web" Version="4.7.0" />
    <PackageReference Include="Microsoft.Identity.Web.GraphServiceClient" Version="4.7.0" />
    <PackageReference Include="Microsoft.Identity.Web.UI" Version="4.7.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MeetingApp.Application\MeetingApp.Application.csproj" />
    <ProjectReference Include="..\MeetingApp.Infrastructure\MeetingApp.Infrastructure.csproj" />
  </ItemGroup>

</Project>
